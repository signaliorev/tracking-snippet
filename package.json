{
  "name": "@signalio/tracking-snippet",
  "version": "1.0.0",
  "description": "Tracking snippet for signalio.com — lightweight analytics library",
  "keywords": [
    "analytics",
    "tracking",
    "signalio",
    "snippet"
  ],
  "homepage": "https://github.com/signaliorev/tracking-snippet#readme",
  "bugs": {
    "url": "https://github.com/signaliorev/tracking-snippet/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signaliorev/tracking-snippet.git"
  },
  "license": "Apache-2.0",
  "author": "signalio",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "lint": "eslint src",
    "test": "jest",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-replace": "^5.0.5",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^4.14.0"
  }
}
